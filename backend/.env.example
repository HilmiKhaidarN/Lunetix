PORT=3000

# Supabase - dapatkan dari: supabase.com > Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=your_jwt_secret_here

# URL frontend yang diizinkan akses API (pisahkan dengan koma jika lebih dari satu)
ALLOWED_ORIGINS=https://lunetix-rust.vercel.app

# URL site untuk redirect reset password
SITE_URL=https://lunetix-rust.vercel.app

# Groq AI API Key - dapatkan dari: console.groq.com
GROQ_API_KEY=
