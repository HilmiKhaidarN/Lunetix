PORT=3000

# Supabase - dapatkan dari: supabase.com > Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=your_jwt_secret_here

# URL frontend yang diizinkan akses API (pisahkan dengan koma jika lebih dari satu)
ALLOWED_ORIGINS=https://lunetix-rust.vercel.app

# URL site untuk redirect reset password
SITE_URL=https://lunetix-rust.vercel.app

# Groq AI API Key - dapatkan dari: console.groq.com
GROQ_API_KEY=

# Stripe Payment - dapatkan dari: dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_PRO_YEARLY_PRICE_ID=price_your_pro_yearly_price_id
STRIPE_TEAM_MONTHLY_PRICE_ID=price_your_team_monthly_price_id

# Admin Access - email admin yang bisa akses dashboard admin (pisahkan dengan koma)
ADMIN_EMAILS=admin@example.com,your-email@example.com
